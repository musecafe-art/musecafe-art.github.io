---
const categories = [
  { id: 'all', name: 'Full Menu' },
  { id: 'signature', name: 'Signature Entrées' },
  { id: 'burger', name: 'Artisan Burgers' },
  { id: 'coffee', name: 'Specialty Coffee' }
];

const menuItems = [
  {
    id: 1,
    name: 'Ossobuco Mashed Potato',
    category: 'signature',
    description: 'Our house masterpiece. 8-hour slow-braised tender veal shank, served over a rich bed of creamy yellow mashed potatoes, garnished with fresh rosemary and a golden reduction sauce.',
    price: '₹890',
    tag: "Chef's Signature",
    highlighted: true,
    image: '/images/ossobuco.png'
  },
  {
    id: 2,
    name: 'Spaghetti Porcini Chicken',
    category: 'signature',
    description: 'Rich, earthy wild porcini mushroom cream sauce tossed with artisanal bronze-cut spaghetti, topped with grilled tender chicken breast and fresh shaved Parmigiano-Reggiano.',
    price: '₹520',
    tag: 'Popular',
    highlighted: false,
    image: null
  },
  {
    id: 3,
    name: 'Chicken Monsu Soup',
    category: 'signature',
    description: 'A smooth, velvety cream of roasted chicken soup infused with fresh garden herbs, truffle oil, and cracked black pepper, accompanied by toasted house sourdough.',
    price: '₹290',
    tag: 'New',
    highlighted: false,
    image: null
  },
  {
    id: 4,
    name: 'Smashed Beef Burger',
    category: 'burger',
    description: 'Double smashed premium beef patties, melted sharp English cheddar, caramelized white onions, and our signature truffle oil aioli on a toasted buttered brioche bun.',
    price: '₹450',
    tag: 'Gourmet',
    highlighted: false,
    image: null
  },
  {
    id: 5,
    name: 'Crispy Chicken Burger',
    category: 'burger',
    description: 'Crispy buttermilk fried chicken breast, spicy house slaw, dill pickles, and garlic emulsion served in a toasted brioche bun with a side of seasoned skin-on fries.',
    price: '₹420',
    tag: null,
    highlighted: false,
    image: null
  },
  {
    id: 6,
    name: 'White Chocolate Frappe',
    category: 'coffee',
    description: 'A luxurious blended espresso cream frappe infused with premium Belgian white chocolate, topped with cold organic whipped cream and white chocolate shavings.',
    price: '₹320',
    tag: 'Signature Drink',
    highlighted: false,
    image: null
  },
  {
    id: 7,
    name: 'Classic Double Espresso',
    category: 'coffee',
    description: 'Perfectly extracted double shot ristretto using organic single-origin Arabica beans, featuring a rich hazelnut crema and complex chocolatey notes.',
    price: '₹180',
    tag: 'Craft',
    highlighted: false,
    image: null
  },
  {
    id: 8,
    name: 'Iced Rose Latte',
    category: 'coffee',
    description: 'A floral, refreshing iced latte layered with organic Damask rose essence, double shot espresso, and silky cold-foamed organic milk, served over crystal clear ice.',
    price: '₹280',
    tag: 'Aesthetic',
    highlighted: false,
    image: null
  }
];
---

<section id="menu" class="section section-dark menu-section">
  <!-- Decorative Background elements -->
  <div class="menu-bg-accent"></div>

  <div class="container">
    <!-- Section Header -->
    <div class="section-header">
      <span class="section-subtitle">Gastronomy Card</span>
      <h2 class="section-title">The Evening <span class="text-gradient">Selection</span></h2>
      <div class="divider divider-gold">
        <span class="divider-diamond"></span>
      </div>
      <p class="section-desc">
        A curated fusion of slow-cooked fine dining, comforting house-made burgers, and exquisite specialty coffee. Every dish is a composition of taste and design.
      </p>
    </div>

    <!-- Filter Buttons -->
    <div class="filter-wrapper">
      <div class="filter-buttons">
        {categories.map((cat, index) => (
          <button 
            class={`filter-btn ${index === 0 ? 'active' : ''}`}
            data-filter={cat.id}
          >
            {cat.name}
          </button>
        ))}
      </div>
    </div>

    <!-- Menu Grid -->
    <div class="menu-grid" id="menu-grid">
      {menuItems.map(item => (
        <div 
          class={`menu-card-wrapper filter-item ${item.category} ${item.highlighted ? 'highlighted-item' : ''}`}
          data-category={item.category}
        >
          {item.highlighted ? (
            /* Special Highlight Card with Image */
            <div class="highlight-menu-card">
              <div class="highlight-img-wrapper">
                <img src={item.image} alt={item.name} class="highlight-img" />
                <div class="highlight-tag">{item.tag}</div>
              </div>
              <div class="highlight-details">
                <div class="card-header">
                  <h3 class="item-name">{item.name}</h3>
                  <span class="item-price text-gradient">{item.price}</span>
                </div>
                <p class="item-desc">{item.description}</p>
                <div class="card-footer">
                  <span class="craft-tag">✨ Slow-Braised 8 Hours</span>
                  <a href="#inquiry" class="order-btn-accent">Order to Table</a>
                </div>
              </div>
            </div>
          ) : (
            /* Standard Luxury Card */
            <div class="standard-menu-card">
              <div class="card-top">
                {item.tag && <span class="card-tag">{item.tag}</span>}
                <span class="item-category-label">{item.category}</span>
              </div>
              <div class="card-header">
                <h3 class="item-name">{item.name}</h3>
                <span class="price-separator"></span>
                <span class="item-price">{item.price}</span>
              </div>
              <p class="item-desc">{item.description}</p>
              <div class="card-footer-standard">
                <a href="#inquiry" class="inquire-link">Table Service &rarr;</a>
              </div>
            </div>
          )}
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .menu-section {
    position: relative;
    overflow: hidden;
  }

  /* Dark glowing accent in background */
  .menu-bg-accent {
    position: absolute;
    top: 30%;
    right: -10%;
    width: 500px;
    height: 500px;
    background: radial-gradient(circle, rgba(197, 168, 128, 0.05) 0%, transparent 70%);
    z-index: 1;
    pointer-events: none;
  }

  .container {
    position: relative;
    z-index: 2;
  }

  /* Filter Navigation styling */
  .filter-wrapper {
    display: flex;
    justify-content: center;
    margin-bottom: 4rem;
  }

  .filter-buttons {
    display: flex;
    gap: 0.75rem;
    background-color: rgba(5, 18, 11, 0.6);
    border: 1px solid rgba(197, 168, 128, 0.15);
    padding: 0.5rem;
    border-radius: 50px;
    backdrop-filter: blur(10px);
    overflow-x: auto;
    max-width: 100%;
    scrollbar-width: none; /* Firefox */
  }

  .filter-buttons::-webkit-scrollbar {
    display: none; /* Safari & Chrome */
  }

  .filter-btn {
    font-family: var(--font-sans);
    font-size: 0.85rem;
    font-weight: 600;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    color: var(--color-text-light-muted);
    padding: 0.75rem 1.5rem;
    border-radius: 50px;
    transition: var(--transition-smooth);
    white-space: nowrap;
  }

  .filter-btn:hover {
    color: var(--color-text-light);
  }

  .filter-btn.active {
    background-color: var(--color-gold);
    color: var(--color-primary-dark);
    box-shadow: 0 4px 15px rgba(197, 168, 128, 0.3);
  }

  /* Menu Cards Grid Layout */
  .menu-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 2.5rem;
    transition: var(--transition-smooth);
  }

  /* Responsive Adjustments */
  @media (max-width: 991px) {
    .menu-grid {
      grid-template-columns: 1fr;
      gap: 2rem;
    }
  }

  /* Grid wrapper for smooth filter animations */
  .menu-card-wrapper {
    transition: opacity 0.5s cubic-bezier(0.16, 1, 0.3, 1), transform 0.5s cubic-bezier(0.16, 1, 0.3, 1);
    transform-origin: center;
    opacity: 1;
    transform: scale(1);
    height: auto;
  }

  .menu-card-wrapper.hidden {
    opacity: 0;
    transform: scale(0.92);
    pointer-events: none;
    position: absolute;
    width: 0;
    height: 0;
    overflow: hidden;
    margin: 0;
    padding: 0;
    border: none;
  }

  /* Double-width highlighted showcase item */
  .highlighted-item {
    grid-column: span 2;
  }

  @media (max-width: 991px) {
    .highlighted-item {
      grid-column: span 1;
    }
  }

  /* Highlight Showcase Card Design */
  .highlight-menu-card {
    display: grid;
    grid-template-columns: 0.9fr 1.1fr;
    background-color: rgba(22, 54, 37, 0.4);
    border: 1px solid var(--color-gold);
    border-radius: var(--border-radius-md);
    overflow: hidden;
    box-shadow: 0 10px 45px rgba(5, 18, 11, 0.6);
    transition: var(--transition-smooth);
  }

  @media (max-width: 768px) {
    .highlight-menu-card {
      grid-template-columns: 1fr;
    }
  }

  .highlight-menu-card:hover {
    transform: translateY(-5px);
    border-color: var(--color-gold-bright);
    box-shadow: 0 15px 50px rgba(197, 168, 128, 0.15);
  }

  .highlight-img-wrapper {
    position: relative;
    overflow: hidden;
    height: 100%;
    min-height: 250px;
  }

  .highlight-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: var(--transition-smooth);
  }

  .highlight-menu-card:hover .highlight-img {
    transform: scale(1.05);
  }

  .highlight-tag {
    position: absolute;
    top: 1.25rem;
    left: 1.25rem;
    background-color: var(--color-gold-bright);
    color: var(--color-primary-dark);
    font-size: 0.7rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    padding: 0.4rem 1rem;
    border-radius: 4px;
    box-shadow: var(--shadow-sm);
  }

  .highlight-details {
    padding: 2.5rem;
    display: flex;
    flex-direction: column;
    justify-content: center;
  }

  @media (max-width: 576px) {
    .highlight-details {
      padding: 1.5rem;
    }
  }

  .highlight-details .item-name {
    font-size: 1.8rem;
    color: var(--color-text-light);
    margin-bottom: 0.5rem;
  }

  .highlight-details .item-price {
    font-size: 1.6rem;
    font-weight: 600;
    font-family: var(--font-serif);
  }

  .highlight-details .item-desc {
    font-size: 0.95rem;
    color: var(--color-text-light-muted);
    line-height: 1.6;
    margin: 1rem 0 2rem 0;
  }

  .highlight-details .card-footer {
    display: flex;
    align-items: center;
    justify-content: space-between;
    border-top: 1px solid rgba(197, 168, 128, 0.15);
    padding-top: 1.5rem;
  }

  .craft-tag {
    font-size: 0.85rem;
    color: var(--color-gold);
    font-weight: 500;
  }

  .order-btn-accent {
    font-family: var(--font-sans);
    font-size: 0.8rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--color-gold-bright);
    transition: var(--transition-smooth);
  }

  .order-btn-accent:hover {
    color: var(--color-text-light);
    transform: translateX(4px);
  }

  /* Standard Card Design */
  .standard-menu-card {
    background-color: rgba(22, 54, 37, 0.15);
    border: 1px solid rgba(197, 168, 128, 0.08);
    border-radius: var(--border-radius-md);
    padding: 2.25rem;
    display: flex;
    flex-direction: column;
    height: 100%;
    transition: var(--transition-smooth);
  }

  @media (max-width: 576px) {
    .standard-menu-card {
      padding: 1.5rem;
    }
  }

  .standard-menu-card:hover {
    transform: translateY(-5px);
    border-color: rgba(197, 168, 128, 0.3);
    background-color: rgba(22, 54, 37, 0.3);
    box-shadow: var(--shadow-md);
  }

  .card-top {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 1.25rem;
  }

  .card-tag {
    background-color: rgba(197, 168, 128, 0.15);
    color: var(--color-gold);
    border: 1px solid rgba(197, 168, 128, 0.3);
    font-size: 0.65rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    padding: 0.25rem 0.75rem;
    border-radius: 4px;
  }

  .item-category-label {
    font-size: 0.65rem;
    font-family: var(--font-sans);
    text-transform: uppercase;
    letter-spacing: 0.15em;
    font-weight: 600;
    color: rgba(197, 168, 128, 0.4);
  }

  .standard-menu-card:hover .item-category-label {
    color: var(--color-gold);
  }

  .standard-menu-card .card-header {
    display: flex;
    align-items: baseline;
    gap: 0.75rem;
    width: 100%;
    margin-bottom: 0.75rem;
  }

  .standard-menu-card .item-name {
    font-size: 1.3rem;
    color: var(--color-text-light);
    font-weight: 500;
    white-space: nowrap;
  }

  .price-separator {
    flex-grow: 1;
    border-bottom: 1px dashed rgba(197, 168, 128, 0.15);
    height: 1px;
  }

  .standard-menu-card:hover .price-separator {
    border-bottom-color: rgba(197, 168, 128, 0.4);
  }

  .standard-menu-card .item-price {
    font-size: 1.25rem;
    font-family: var(--font-serif);
    color: var(--color-gold);
    font-weight: 600;
  }

  .standard-menu-card .item-desc {
    font-size: 0.9rem;
    color: var(--color-text-light-muted);
    line-height: 1.6;
    margin-bottom: 1.5rem;
    flex-grow: 1;
  }

  .card-footer-standard {
    border-top: 1px solid rgba(255, 255, 255, 0.05);
    padding-top: 1rem;
    display: flex;
    justify-content: flex-end;
  }

  .inquire-link {
    font-size: 0.8rem;
    font-family: var(--font-sans);
    font-weight: 600;
    color: rgba(197, 168, 128, 0.6);
    letter-spacing: 0.05em;
  }

  .standard-menu-card:hover .inquire-link {
    color: var(--color-gold-bright);
  }
</style>

<script>
  // Filter Engine
  const filterButtons = document.querySelectorAll('.filter-btn');
  const menuItems = document.querySelectorAll('.filter-item');
  const menuGrid = document.getElementById('menu-grid');

  filterButtons.forEach(button => {
    button.addEventListener('click', () => {
      // Toggle active button state
      filterButtons.forEach(btn => btn.classList.remove('active'));
      button.classList.add('active');

      const filterValue = button.getAttribute('data-filter') || 'all';

      // Animate grid exit
      if (menuGrid) {
        menuGrid.style.opacity = '0.3';
        menuGrid.style.transform = 'translateY(10px)';
      }

      setTimeout(() => {
        menuItems.forEach(item => {
          const itemCategory = item.getAttribute('data-category') || '';
          
          if (filterValue === 'all') {
            item.classList.remove('hidden');
          } else if (filterValue === 'signature' && itemCategory === 'signature') {
            item.classList.remove('hidden');
          } else if (filterValue === 'burger' && itemCategory === 'burger') {
            item.classList.remove('hidden');
          } else if (filterValue === 'coffee' && itemCategory === 'coffee') {
            item.classList.remove('hidden');
          } else {
            item.classList.add('hidden');
          }
        });

        // Animate grid re-entry
        if (menuGrid) {
          menuGrid.style.opacity = '1';
          menuGrid.style.transform = 'translateY(0)';
        }
      }, 350);
    });
  });
</script>
