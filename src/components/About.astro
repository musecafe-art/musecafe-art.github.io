---
---
<section id="about" class="section section-light about-section">
  <!-- Soft background textures -->
  <div class="about-bg-texture"></div>

  <div class="container about-container">
    <div class="grid-layout">
      <!-- Story Content Column -->
      <div class="content-col">
        <span class="section-subtitle">The Muse Concept</span>
        <h2 class="section-title">Where Gastronomy Meets <span class="text-gold">Artistry</span></h2>
        
        <div class="about-divider">
          <span class="divider-diamond"></span>
          <span class="divider-line"></span>
        </div>

        <p class="about-lead">
          Muse is more than a cafe; it is a sensory escape hidden away on 100 Feet Road in Palakkad. An evening oasis designed for epicures, art lovers, and conversations that linger past midnight.
        </p>

        <p class="about-text">
          Conceived as a live gallery and culinary laboratory, our space breathes creativity. As the sun sets, our outdoor garden lights glow, setting the stage for fine dining under the open skies. We believe in the slow arts: from curating modern abstract paintings that line our textured neutral walls, to our signature <strong>8-hour slow-braised Ossobuco</strong> that melts onto the palate.
        </p>

        <!-- Dynamic Value Props -->
        <div class="value-props">
          <div class="prop-item">
            <div class="prop-icon">🍽️</div>
            <div class="prop-details">
              <h3>Artisanal Gastronomy</h3>
              <p>Fine ingredients meets slow-cooking. Highlights include our braised veal shanks, hand-crafted smashed burgers, and premium porcini pastas.</p>
            </div>
          </div>
          
          <div class="prop-item">
            <div class="prop-icon">🎨</div>
            <div class="prop-details">
              <h3>Curated Art Gallery</h3>
              <p>Every corner is an exhibition. We showcase local contemporary oil paintings on rotating easels, creating a workspace and dining environment alive with inspiration.</p>
            </div>
          </div>

          <div class="prop-item">
            <div class="prop-icon">☕</div>
            <div class="prop-details">
              <h3>Artisanal Brew Culture</h3>
              <p>From micro-foamed latte art to our signature iced rose and white chocolate frappes, we approach coffee with pure barista precision.</p>
            </div>
          </div>
        </div>

        <!-- Schedule CTA Badge -->
        <div class="schedule-callout">
          <span class="callout-icon">✨</span>
          <p>Join us for our **Soft Launch Weekend Phase**:<br /><strong>Friday to Sunday: 4:00 PM – 1:00 AM</strong>. Experience Palakkad's night garden vibe.</p>
        </div>
      </div>

      <!-- Image Collage Column -->
      <div class="image-col">
        <div class="frame-container">
          <!-- Elegant gold decorative border -->
          <div class="gold-border-decor"></div>
          <div class="image-wrapper">
            <img src="/images/coffee.png" alt="Barista pouring gourmet specialty coffee at Muse Cafe" class="about-img" />
          </div>
          <!-- Decorative Monogram Stamp -->
          <div class="about-monogram-stamp">
            <span class="stamp-text">EST. 2026</span>
            <span class="stamp-letter">M</span>
          </div>
        </div>
        
        <div class="experience-badge animate-float">
          <span class="badge-num">100%</span>
          <span class="badge-label">Artisanal & Craft</span>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .about-section {
    position: relative;
    overflow: hidden;
  }

  /* Soft Background Texture */
  .about-bg-texture {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background-image: radial-gradient(rgba(197, 168, 128, 0.05) 1.5px, transparent 1.5px);
    background-size: 30px 30px;
    z-index: 1;
    pointer-events: none;
  }

  .about-container {
    position: relative;
    z-index: 2;
  }

  .grid-layout {
    display: grid;
    grid-template-columns: 1.1fr 0.9fr;
    gap: 5rem;
    align-items: center;
  }

  @media (max-width: 991px) {
    .grid-layout {
      grid-template-columns: 1fr;
      gap: 4rem;
    }
  }

  /* Content Column Styles */
  .content-col {
    display: flex;
    flex-direction: column;
  }

  .about-divider {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    margin: 0.5rem 0 2rem 0;
  }

  .divider-line {
    height: 1px;
    flex-grow: 1;
    max-width: 120px;
    background: linear-gradient(90deg, var(--color-gold), transparent);
  }

  .about-lead {
    font-size: 1.25rem;
    line-height: 1.6;
    color: var(--color-primary-light);
    font-family: var(--font-serif);
    margin-bottom: 1.5rem;
  }

  .about-text {
    font-size: 1rem;
    line-height: 1.7;
    color: var(--color-text-muted);
    margin-bottom: 2.5rem;
  }

  /* Value Props */
  .value-props {
    display: flex;
    flex-direction: column;
    gap: 1.75rem;
    margin-bottom: 2.5rem;
  }

  .prop-item {
    display: flex;
    gap: 1.25rem;
  }

  .prop-icon {
    font-size: 1.75rem;
    background-color: var(--color-cream-dark);
    width: 55px;
    height: 55px;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: 50%;
    flex-shrink: 0;
    box-shadow: var(--shadow-sm);
    border: 1px solid rgba(197, 168, 128, 0.25);
  }

  .prop-details h3 {
    font-size: 1.15rem;
    font-family: var(--font-sans);
    font-weight: 600;
    color: var(--color-primary);
    margin-bottom: 0.25rem;
  }

  .prop-details p {
    font-size: 0.92rem;
    color: var(--color-text-muted);
    line-height: 1.5;
  }

  /* Schedule callout block */
  .schedule-callout {
    background-color: var(--color-primary-dark);
    color: var(--color-text-light);
    border-left: 3px solid var(--color-gold-bright);
    padding: 1.25rem 1.5rem;
    border-radius: 0 var(--border-radius-md) var(--border-radius-md) 0;
    box-shadow: var(--shadow-md);
    display: flex;
    gap: 1rem;
    align-items: center;
  }

  .schedule-callout p {
    font-size: 0.95rem;
    line-height: 1.5;
  }

  .schedule-callout strong {
    color: var(--color-gold-bright);
  }

  .callout-icon {
    font-size: 1.5rem;
    color: var(--color-gold-bright);
    animation: float 4s ease-in-out infinite;
  }

  /* Image Column Styles */
  .image-col {
    position: relative;
    padding: 1.5rem;
  }

  .frame-container {
    position: relative;
    z-index: 2;
  }

  .image-wrapper {
    overflow: hidden;
    border-radius: var(--border-radius-sm);
    box-shadow: var(--shadow-lg);
    background-color: var(--color-primary-dark);
    position: relative;
    z-index: 2;
  }

  .about-img {
    width: 100%;
    object-fit: cover;
    transition: var(--transition-smooth);
  }

  .frame-container:hover .about-img {
    transform: scale(1.05);
  }

  .gold-border-decor {
    position: absolute;
    top: -15px;
    left: -15px;
    right: 15px;
    bottom: 15px;
    border: 2px solid var(--color-gold);
    border-radius: var(--border-radius-sm);
    pointer-events: none;
    z-index: 1;
    transition: var(--transition-smooth);
  }

  .frame-container:hover .gold-border-decor {
    transform: translate(8px, 8px);
    border-color: var(--color-gold-bright);
  }

  /* Decorative stamp */
  .about-monogram-stamp {
    position: absolute;
    bottom: -30px;
    left: -30px;
    width: 100px;
    height: 100px;
    background-color: var(--color-primary);
    border: 1px dashed var(--color-gold);
    border-radius: 50%;
    z-index: 3;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    box-shadow: var(--shadow-md);
  }

  .stamp-text {
    font-size: 0.55rem;
    color: var(--color-text-light-muted);
    letter-spacing: 0.1em;
    font-weight: 600;
  }

  .stamp-letter {
    font-family: var(--font-serif);
    font-size: 2rem;
    font-weight: 700;
    color: var(--color-gold-bright);
    line-height: 1;
    margin-top: -2px;
  }

  /* Experience Badge */
  .experience-badge {
    position: absolute;
    top: 40px;
    right: -20px;
    background-color: var(--color-gold-bright);
    color: var(--color-primary-dark);
    padding: 1.25rem;
    border-radius: var(--border-radius-md);
    box-shadow: var(--shadow-lg);
    display: flex;
    flex-direction: column;
    align-items: center;
    z-index: 4;
  }

  .badge-num {
    font-family: var(--font-serif);
    font-size: 2rem;
    font-weight: 700;
    line-height: 1;
  }

  .badge-label {
    font-size: 0.65rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    margin-top: 0.25rem;
  }

  @media (max-width: 576px) {
    .experience-badge {
      right: 0;
      top: 10px;
      padding: 0.75rem;
    }
    .badge-num {
      font-size: 1.5rem;
    }
    .about-monogram-stamp {
      bottom: -15px;
      left: -15px;
      width: 80px;
      height: 80px;
    }
    .stamp-letter {
      font-size: 1.5rem;
    }
  }
</style>
