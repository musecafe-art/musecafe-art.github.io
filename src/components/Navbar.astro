---
---
<header id="main-header" class="nav-header">
  <div class="container nav-container">
    <!-- Brand Logo -->
    <a href="#" class="nav-logo">
      <span class="logo-monogram">M</span>
      <span class="logo-text">MUSE <span class="logo-sub">Café & Art</span></span>
    </a>

    <!-- Desktop Navigation Links -->
    <nav class="nav-menu">
      <a href="#" class="nav-link active">Home</a>
      <a href="#about" class="nav-link">Our Story</a>
      <a href="#menu" class="nav-link">Menu</a>
      <a href="#gallery" class="nav-link">Gallery</a>
      <a href="#info" class="nav-link">Hours & Location</a>
    </nav>

    <!-- Navigation CTA -->
    <div class="nav-actions">
      <a href="#inquiry" class="btn-nav">Reserve Table</a>
      <!-- Mobile Menu Toggle Button -->
      <button class="mobile-toggle" aria-label="Toggle Menu" id="mobile-toggle">
        <span class="bar"></span>
        <span class="bar"></span>
        <span class="bar"></span>
      </button>
    </div>
  </div>

  <!-- Mobile Drawer Overlay -->
  <div class="mobile-drawer" id="mobile-drawer">
    <div class="drawer-header">
      <a href="#" class="nav-logo">
        <span class="logo-monogram">M</span>
        <span class="logo-text text-light">MUSE</span>
      </a>
      <button class="drawer-close" id="drawer-close" aria-label="Close Menu">&times;</button>
    </div>
    <nav class="drawer-menu">
      <a href="#" class="drawer-link">Home</a>
      <a href="#about" class="drawer-link">Our Story</a>
      <a href="#menu" class="drawer-link">Menu</a>
      <a href="#gallery" class="drawer-link">Gallery</a>
      <a href="#info" class="drawer-link">Hours & Location</a>
      <a href="#inquiry" class="drawer-link drawer-btn">Reserve Table</a>
    </nav>
  </div>
  <div class="drawer-overlay" id="drawer-overlay"></div>
</header>

<style>
  /* Header Floating Base */
  .nav-header {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    z-index: 1000;
    padding: 1.75rem 0;
    transition: var(--transition-smooth);
    border-bottom: 1px solid rgba(255, 255, 255, 0.03);
    background-color: transparent;
  }

  /* Scrolled State via JS */
  .nav-header.scrolled {
    padding: 1rem 0;
    background-color: rgba(11, 34, 22, 0.85);
    backdrop-filter: blur(20px);
    -webkit-backdrop-filter: blur(20px);
    border-bottom: 1px solid rgba(197, 168, 128, 0.15);
    box-shadow: var(--shadow-md);
  }

  .nav-container {
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  /* Logo Branding */
  .nav-logo {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    color: var(--color-text-light);
  }

  .logo-monogram {
    font-family: var(--font-serif);
    font-size: 1.5rem;
    font-weight: 700;
    color: var(--color-gold-bright);
    width: 40px;
    height: 40px;
    display: flex;
    align-items: center;
    justify-content: center;
    border: 1px solid var(--color-gold);
    border-radius: 50%;
    background-color: rgba(11, 34, 22, 0.4);
    box-shadow: 0 0 10px rgba(197, 168, 128, 0.15);
  }

  .logo-text {
    font-family: var(--font-serif);
    font-size: 1.3rem;
    font-weight: 600;
    letter-spacing: 0.1em;
    display: flex;
    flex-direction: column;
    line-height: 1;
  }

  .logo-sub {
    font-family: var(--font-sans);
    font-size: 0.65rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--color-gold);
    margin-top: 0.2rem;
  }

  /* Menu Links */
  .nav-menu {
    display: flex;
    gap: 2.5rem;
    align-items: center;
  }

  .nav-link {
    font-family: var(--font-sans);
    font-size: 0.9rem;
    font-weight: 500;
    letter-spacing: 0.05em;
    color: var(--color-text-light-muted);
    position: relative;
    padding: 0.5rem 0;
  }

  .nav-link::after {
    content: '';
    position: absolute;
    bottom: 0;
    left: 0;
    width: 0;
    height: 1px;
    background-color: var(--color-gold-bright);
    transition: var(--transition-smooth);
  }

  .nav-link:hover, .nav-link.active {
    color: var(--color-text-light);
  }

  .nav-link:hover::after, .nav-link.active::after {
    width: 100%;
  }

  /* Actions & Button */
  .nav-actions {
    display: flex;
    align-items: center;
    gap: 1.5rem;
  }

  .btn-nav {
    display: inline-block;
    padding: 0.6rem 1.5rem;
    font-family: var(--font-sans);
    font-weight: 600;
    font-size: 0.8rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-gold-bright);
    border: 1px solid var(--color-gold);
    border-radius: var(--border-radius-sm);
    transition: var(--transition-smooth);
    background-color: rgba(197, 168, 128, 0.05);
  }

  .btn-nav:hover {
    background-color: var(--color-gold);
    color: var(--color-primary-dark);
    box-shadow: 0 4px 15px rgba(197, 168, 128, 0.3);
    border-color: var(--color-gold);
    transform: translateY(-1px);
  }

  /* Mobile toggle button */
  .mobile-toggle {
    display: none;
    flex-direction: column;
    gap: 5px;
    cursor: pointer;
  }

  .mobile-toggle .bar {
    width: 25px;
    height: 2px;
    background-color: var(--color-text-light);
    transition: var(--transition-smooth);
  }

  /* Responsive Rules */
  @media (max-width: 991px) {
    .nav-menu {
      display: none;
    }
    
    .mobile-toggle {
      display: flex;
    }

    .btn-nav {
      display: none; /* Hide in header, show in drawer */
    }
  }

  /* Drawer Menu Styles */
  .mobile-drawer {
    position: fixed;
    top: 0;
    right: -320px;
    width: 320px;
    height: 100vh;
    background-color: var(--color-primary-dark);
    border-left: 1px solid rgba(197, 168, 128, 0.2);
    z-index: 2000;
    padding: 2rem 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 3rem;
    transition: right 0.4s cubic-bezier(0.16, 1, 0.3, 1);
    box-shadow: var(--shadow-lg);
  }

  .mobile-drawer.open {
    right: 0;
  }

  .drawer-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  .drawer-close {
    font-size: 2.5rem;
    color: var(--color-gold);
    line-height: 1;
  }

  .drawer-close:hover {
    color: var(--color-gold-bright);
  }

  .drawer-menu {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  .drawer-link {
    font-size: 1.1rem;
    font-family: var(--font-serif);
    color: var(--color-text-light-muted);
    padding: 0.5rem 0;
    border-bottom: 1px solid rgba(255, 255, 255, 0.05);
  }

  .drawer-link:hover {
    color: var(--color-gold-bright);
    padding-left: 0.5rem;
  }

  .drawer-btn {
    margin-top: 1rem;
    text-align: center;
    border: 1px solid var(--color-gold);
    color: var(--color-gold);
    border-radius: var(--border-radius-sm);
    padding: 0.75rem;
  }

  .drawer-btn:hover {
    background-color: var(--color-gold);
    color: var(--color-primary-dark);
    padding-left: 0;
  }

  /* Overlay */
  .drawer-overlay {
    position: fixed;
    top: 0;
    left: 0;
    width: 100vw;
    height: 100vh;
    background-color: rgba(5, 18, 11, 0.6);
    backdrop-filter: blur(4px);
    z-index: 1999;
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.4s ease;
  }

  .drawer-overlay.open {
    opacity: 1;
    pointer-events: auto;
  }
</style>

<script>
  // Scroll Handler to shrink header
  const header = document.getElementById('main-header');
  window.addEventListener('scroll', () => {
    if (window.scrollY > 50) {
      header?.classList.add('scrolled');
    } else {
      header?.classList.remove('scrolled');
    }
  });

  // Mobile Drawer Toggle
  const mobileToggle = document.getElementById('mobile-toggle');
  const drawerClose = document.getElementById('drawer-close');
  const drawer = document.getElementById('mobile-drawer');
  const overlay = document.getElementById('drawer-overlay');
  const drawerLinks = document.querySelectorAll('.drawer-link');

  function openDrawer() {
    drawer?.classList.add('open');
    overlay?.classList.add('open');
    document.body.style.overflow = 'hidden';
  }

  function closeDrawer() {
    drawer?.classList.remove('open');
    overlay?.classList.remove('open');
    document.body.style.overflow = '';
  }

  mobileToggle?.addEventListener('click', openDrawer);
  drawerClose?.addEventListener('click', closeDrawer);
  overlay?.addEventListener('click', closeDrawer);

  drawerLinks.forEach(link => {
    link.addEventListener('click', closeDrawer);
  });

  // Dynamic Navigation Link Highlighting on Scroll
  const sections = document.querySelectorAll('section[id]');
  const navLinks = document.querySelectorAll('.nav-link');

  window.addEventListener('scroll', () => {
    let current = '';
    const scrollPos = window.scrollY + 100;

    sections.forEach(section => {
      const sectionTop = (section as HTMLElement).offsetTop;
      const sectionHeight = (section as HTMLElement).offsetHeight;
      if (scrollPos >= sectionTop && scrollPos < sectionTop + sectionHeight) {
        current = section.getAttribute('id') || '';
      }
    });

    navLinks.forEach(link => {
      link.classList.remove('active');
      const href = link.getAttribute('href');
      if (href === '#' && current === '') {
        link.classList.add('active');
      } else if (href === `#${current}`) {
        link.classList.add('active');
      }
    });
  });
</script>
