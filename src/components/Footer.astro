---
---
<footer class="footer-section">
  <div class="container footer-container">
    
    <!-- Footer Branding Column -->
    <div class="footer-brand">
      <a href="#" class="brand-logo">
        <span class="logo-monogram">M</span>
        <span class="logo-text">MUSE</span>
      </a>
      <p class="brand-desc">
        A premium evening garden cafe blending slow-braised gastronomy with rotating curated fine art collections. Established 2026.
      </p>
      <div class="social-links">
        <a href="https://www.instagram.com/musecafe.art/" target="_blank" rel="noopener noreferrer" class="social-btn" aria-label="Instagram">
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <rect x="2" y="2" width="20" height="20" rx="5" ry="5"></rect>
            <path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"></path>
            <line x1="17.5" y1="6.5" x2="17.51" y2="6.5"></line>
          </svg>
          <span>@musecafe.art</span>
        </a>
      </div>
    </div>

    <!-- Quick Links Column -->
    <div class="footer-links-col">
      <h4 class="column-title">Explore</h4>
      <nav class="footer-links">
        <a href="#">Home</a>
        <a href="#about">Our Story</a>
        <a href="#menu">Evening Menu</a>
        <a href="#gallery">Art Exhibition</a>
        <a href="#info">Schedule & Location</a>
      </nav>
    </div>

    <!-- Soft Launch Details Column -->
    <div class="footer-hours-col">
      <h4 class="column-title">Soft Launch Schedule</h4>
      <p class="hours-info">
        Join us in our evening night garden:
      </p>
      <div class="hours-badge-footer">
        <span class="hours-day">Friday &ndash; Sunday</span>
        <span class="hours-time">4:00 PM &ndash; 1:00 AM</span>
      </div>
      <p class="hours-disclaimer">
        Monday to Thursday the cafe is closed for rotating art curations and chef's private kitchen prep.
      </p>
    </div>

  </div>

  <!-- Ornate golden separator and copyright -->
  <div class="footer-bottom">
    <div class="container bottom-container">
      <div class="bottom-divider"></div>
      <div class="bottom-details">
        <p class="copyright">&copy; {new Date().getFullYear()} MUSE Café & Art. All Rights Reserved.</p>
        <p class="crafted">Designed with &hearts; in Palakkad</p>
      </div>
    </div>
  </div>
</footer>

<style>
  .footer-section {
    background-color: var(--color-primary-dark);
    color: var(--color-text-light);
    padding: 6rem 0 3rem 0;
    border-top: 1px solid rgba(197, 168, 128, 0.15);
    position: relative;
    overflow: hidden;
  }

  .footer-container {
    display: grid;
    grid-template-columns: 1.2fr 0.8fr 1fr;
    gap: 5rem;
    margin-bottom: 4rem;
  }

  @media (max-width: 991px) {
    .footer-container {
      grid-template-columns: 1fr;
      gap: 3.5rem;
    }
  }

  /* Brand Column */
  .footer-brand {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  .brand-logo {
    display: inline-flex;
    align-items: center;
    gap: 0.75rem;
    color: var(--color-text-light);
  }

  .logo-monogram {
    font-family: var(--font-serif);
    font-size: 1.3rem;
    font-weight: 700;
    color: var(--color-gold-bright);
    width: 38px;
    height: 38px;
    display: flex;
    align-items: center;
    justify-content: center;
    border: 1px solid var(--color-gold);
    border-radius: 50%;
    background-color: rgba(11, 34, 22, 0.4);
  }

  .logo-text {
    font-family: var(--font-serif);
    font-size: 1.5rem;
    font-weight: 600;
    letter-spacing: 0.15em;
  }

  .brand-desc {
    font-size: 0.9rem;
    line-height: 1.6;
    color: var(--color-text-light-muted);
  }

  /* Social Instagram Link Button */
  .social-links {
    margin-top: 0.5rem;
  }

  .social-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.75rem;
    padding: 0.6rem 1.25rem;
    background-color: rgba(197, 168, 128, 0.08);
    border: 1px solid rgba(197, 168, 128, 0.25);
    border-radius: 50px;
    font-size: 0.85rem;
    font-weight: 600;
    color: var(--color-gold);
    transition: var(--transition-smooth);
  }

  .social-btn:hover {
    background-color: var(--color-gold);
    color: var(--color-primary-dark);
    border-color: var(--color-gold);
    box-shadow: 0 4px 15px rgba(197, 168, 128, 0.25);
    transform: translateY(-2px);
  }

  /* Column Titles */
  .column-title {
    font-family: var(--font-sans);
    font-size: 0.85rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    color: var(--color-gold);
    margin-bottom: 2rem;
    position: relative;
    padding-bottom: 0.5rem;
  }

  .column-title::after {
    content: '';
    position: absolute;
    bottom: 0;
    left: 0;
    width: 35px;
    height: 1px;
    background-color: var(--color-gold-bright);
  }

  /* Explore Links Column */
  .footer-links {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .footer-links a {
    font-size: 0.95rem;
    color: var(--color-text-light-muted);
    transition: var(--transition-smooth);
    padding: 0.2rem 0;
  }

  .footer-links a:hover {
    color: var(--color-gold-bright);
    padding-left: 0.5rem;
  }

  /* Soft Launch Column */
  .footer-hours-col {
    display: flex;
    flex-direction: column;
  }

  .hours-info {
    font-size: 0.92rem;
    color: var(--color-text-light-muted);
    margin-bottom: 1rem;
  }

  .hours-badge-footer {
    background-color: rgba(5, 18, 11, 0.6);
    border: 1px solid rgba(197, 168, 128, 0.15);
    border-radius: var(--border-radius-sm);
    padding: 1.25rem;
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
    margin-bottom: 1.25rem;
  }

  .hours-day {
    font-size: 0.95rem;
    font-weight: 700;
    color: var(--color-text-light);
  }

  .hours-time {
    font-size: 1.05rem;
    font-weight: 600;
    color: var(--color-gold-bright);
  }

  .hours-disclaimer {
    font-size: 0.8rem;
    font-style: italic;
    color: rgba(197, 168, 128, 0.45);
    line-height: 1.5;
  }

  /* Bottom Details Row */
  .footer-bottom {
    margin-top: 2rem;
  }

  .bottom-divider {
    height: 1px;
    width: 100%;
    background: linear-gradient(90deg, transparent, rgba(197, 168, 128, 0.15), transparent);
    margin-bottom: 2rem;
  }

  .bottom-details {
    display: flex;
    justify-content: space-between;
    align-items: center;
    font-size: 0.8rem;
    color: rgba(197, 168, 128, 0.4);
    letter-spacing: 0.05em;
  }

  @media (max-width: 576px) {
    .bottom-details {
      flex-direction: column;
      gap: 0.75rem;
      text-align: center;
    }
  }

  .copyright {
    line-height: 1.4;
  }

  .crafted {
    font-weight: 500;
  }
</style>
